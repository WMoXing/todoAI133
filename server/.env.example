# ============================================
# AI Todo 环境变量配置
# 复制此文件为 server/.env 填写实际值
# ============================================

# 服务端口 (Render 自动注入 PORT，本地用 3001)
PORT=3001

# DeepSeek API
DEEPSEEK_API_KEY=sk-your-api-key-here
DEEPSEEK_BASE_URL=https://api.deepseek.com

# 缤纷云 (S3-compatible object storage)
# 登录 https://console.bitiful.com 获取
BITIFUL_ACCESS_KEY=your_access_key
BITIFUL_SECRET_KEY=your_secret_key
BITIFUL_BUCKET=todo133
BITIFUL_ENDPOINT=https://s3.bitiful.net